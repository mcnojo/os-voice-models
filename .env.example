FLASK_PORT=5001
FLASK_HOST=0.0.0.0

SAMPLE_RATE=24000

# STT
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM
GGUF_MODEL_PATH=./models/SmolLM3-Q4_K_M.gguf
LLM_THREADS=8
LLM_MAX_TOKENS=128
LLM_TEMPERATURE=0.7

# espeak-ng paths (macOS Homebrew — adjust for Linux/Docker)
PHONEMIZER_ESPEAK_LIBRARY=/opt/homebrew/opt/espeak-ng/lib/libespeak-ng.dylib
PHONEMIZER_ESPEAK_PATH=/opt/homebrew/opt/espeak-ng/bin/espeak-ng
ESPEAK_DATA_PATH=/opt/homebrew/opt/espeak-ng/share/espeak-ng-data

# TTS engine: kokoro | omnivoice | supertonic
TTS_ENGINE=kokoro

# Kokoro
KOKORO_MODEL_NAME=hexgrad/Kokoro-82M
KOKORO_VOICE=bf_isabella
KOKORO_SPEED=1.0
KOKORO_DEVICE=cpu

# OmniVoice (used when TTS_ENGINE=omnivoice)
OMNIVOICE_DEVICE=mps
OMNIVOICE_VOICE=female_american
OMNIVOICE_SPEED=1.0
OMNIVOICE_STEPS=32

# Supertonic-3 (used when TTS_ENGINE=supertonic)
SUPERTONIC_VOICE=M1
SUPERTONIC_SPEED=1.05
SUPERTONIC_STEPS=5
SUPERTONIC_LANG=en

SYSTEM_PROMPT=You are a helpful voice assistant. Provide concise, natural responses suitable for speech. Keep answers brief and conversational.
MAX_HISTORY=10

APP_ENV=local
IS_LOCAL=true
LOG_DIR=logs

# HuggingFace token (only needed for gated models)
# HF_LOCAL_READ_TOKEN=
